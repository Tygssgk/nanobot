router_settings:
  routing_strategy: simple-shuffle
  num_retries: 3
  retry_after: 5
  cooldown_time: 60
  timeout: 60

  fallbacks:
    - gemini-flash:
        - gemini-pro
        - cerebras-smart

    - gemini-pro:
        - gemini-flash
        - cerebras-smart

    - cerebras-smart:
        - gemini-flash
        - gemini-pro

litellm_settings:
  drop_params: true
  modify_params: true
  return_response_headers: false

